# Compliance Gap Analyser — Environment Configuration Example
# Copy this file to .env and fill in the values

# ChromaDB persistence directory
CHROMA_PERSIST_DIRECTORY=data/chroma_db

# Embedding model (sentence-transformers)
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Standards ingestion schedule in hours (default: 168 = weekly)
INGESTION_SCHEDULE_HOURS=168

# Path to standards sources configuration
STANDARDS_SOURCES_FILE=standards_ingestion/sources.yaml

# Path to gap rules JSON file
GAP_RULES_PATH=data/gap_rules.json

# Path to questionnaire JSON file
QUESTIONNAIRE_PATH=data/questionnaire.json

# LLM Configuration (LMStudio)
# Base URL of the LMStudio OpenAI-compatible API endpoint
LLM_BASE_URL=http://192.168.1.59:1234/v1
# Model name to use (must match a model loaded in LMStudio)
LLM_MODEL=qwen/qwen3.6-35b-a3b
# Request timeout in seconds
LLM_TIMEOUT=60
# Maximum number of retry attempts for failed requests
LLM_MAX_RETRIES=2
# Sampling temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.3
# Maximum number of tokens in the model's response
LLM_MAX_TOKENS=4096

# OpenAI / LLM API key (if using LLM features)
# OPENAI_API_KEY=sk-...
